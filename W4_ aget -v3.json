    {
      "parameters": {
        "jsCode": "/* Decide if this account can be dispatched right now */\nconst base = $('Code: Expand queue keys').item.json;\n\n// Queue length (LLEN output is: { \"queue:xxx\": <number> })\nconst lenRaw = $json.length ?? $json.value ?? $json.result ?? Object.values($json)[0] ?? 0;\nconst queueLen = Number(lenRaw) || 0;\n\n// account_lock value (Redis GET usually returns: { propertyName: <value> })\nconst lockObj = $('Redis GET: account_lock (Poller)').item.json || {};\nconst lockVal = lockObj.value ?? lockObj.propertyName ?? Object.values(lockObj)[0];\nconst hasLock = lockVal !== undefined && lockVal !== null && String(lockVal).trim() !== '';\n\n// rate_limit timestamps (Redis GET returns: { propertyName: \"[... ]\" })\nconst rlObj = $('Redis GET: rate_limit_window (Poller)').item.json || {};\nconst rlVal = rlObj.value ?? rlObj.propertyName ?? Object.values(rlObj)[0];\nconst raw = (rlVal ?? '[]').toString();\nlet arr = [];\ntry {\n  const parsed = JSON.parse(raw);\n  if (Array.isArray(parsed)) arr = parsed.map(v => Number(v)).filter(Number.isFinite);\n} catch { arr = []; }\n\nconst now = Math.floor(Date.now() / 1000);\nconst windowMinutes = 30;\nconst maxAttempts = 5;\nconst windowSeconds = Math.max(60, Math.floor(windowMinutes * 60));\nconst cutoff = now - windowSeconds;\nconst recent = arr.filter(ts => ts >= cutoff);\nconst canProceed = recent.length < maxAttempts;\nlet cooldownMinutes = 0;\nif (!canProceed && recent.length > 0) {\n  const oldest = Math.min(...recent);\n  const waitSec = Math.max(0, windowSeconds - (now - oldest));\n  cooldownMinutes = Math.ceil(waitSec / 60);\n}\n\nconst canDispatch = queueLen > 0 && !hasLock && canProceed;\n\nreturn {\n  json: {\n    ...base,\n    queue_len: queueLen,\n    has_lock: hasLock,\n    can_proceed: canProceed,\n    cooldown_minutes: cooldownMinutes,\n    can_dispatch: canDispatch\n  }\n};\n"
      },
