      "parameters": {
        "jsCode": "/* Parse popped queue item + shape it for Workflow 2 */\nconst popped = $json.popped;\nif (!popped) return { json: { popped: false } };\n\n// Redis POP node tries JSON.parse automatically; so popped may already be an object.\nconst item = typeof popped === 'string' ? (() => { try { return JSON.parse(popped); } catch { return null; } })() : popped;\nif (!item || typeof item !== 'object') return { json: { popped: true, raw_item: popped } };\n\nreturn {\n  json: {\n    email: item.email,\n    order_number: item.order_number,\n    phone: item.phone,\n    conversation_id: item.conversation_id,\n    chatwoot_account_id: item.chatwoot_account_id,\n    ExcutedBy: 'ai'\n  }\n};\n"
