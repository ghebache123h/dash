    {
      "parameters": {
        "jsCode": "/* Expand Redis KEYS output to one item per queue key */\nlet keys = $json.keys ?? $json.value ?? $json.result ?? Object.values($json)[0] ?? [];\nif (typeof keys === 'string') {\n  if (keys.includes(',')) keys = keys.split(',').map(s => s.trim()).filter(Boolean);\n  else keys = [keys];\n}\nif (!Array.isArray(keys)) keys = [];\n\nreturn keys\n  .filter(k => typeof k === 'string' && k.startsWith('queue:'))\n  .map(k => ({ json: { queue_key: k, account_key: k.replace(/^queue:/, '') } }));\n"
      },
      "id": "c130f80a-c504-4360-be39-238206ac2f33",
      "name": "Code: Expand queue keys",
